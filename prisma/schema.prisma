generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SENIOR
  JUNIOR
}

/// 위탁 운영 고객사(업체)
model Tenant {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  active    Boolean  @default(true)
  memo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userTenants       UserTenant[]
  companySettings   CompanySettings?
  employees         Employee[]
  levelPaymentRules LevelPaymentRule[]
  levelTargets      LevelTarget[]
  quarterlyRates    QuarterlyRate[]
  auditLogs         AuditLog[]
  glSyncJobs        GlSyncJob[]
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  name             String
  /// 테넌트 미선택 시 기본 표시용(실제 권한은 UserTenant·세션)
  role             Role     @default(JUNIOR)
  isPlatformAdmin  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userTenants UserTenant[]
}

/// 사용자-고객사 소속 및 업체별 역할
model UserTenant {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      Role     @default(JUNIOR)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
}

model CompanySettings {
  id                         String   @id @default(cuid())
  tenantId                   String   @unique
  tenant                     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  foundingMonth              Int      @default(1)
  defaultPayDay              Int      @default(25)
  activeYear                 Int      @default(2026)
  accrualCurrentMonthPayNext Boolean  @default(false)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model Employee {
  id                    String   @id @default(cuid())
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeCode          String
  name                  String
  position              String
  baseSalary            Decimal  @db.Decimal(15, 2)
  adjustedSalary        Decimal  @db.Decimal(15, 2)
  welfareAllocation     Decimal  @db.Decimal(15, 2)
  incentiveAmount       Decimal? @db.Decimal(15, 2)
  discretionaryAmount   Decimal? @db.Decimal(15, 2)
  optionalWelfareAmount Decimal? @db.Decimal(15, 2)
  monthlyPayAmount      Decimal? @db.Decimal(15, 2)
  quarterlyPayAmount    Decimal? @db.Decimal(15, 2)

  birthMonth        Int?
  hireMonth         Int?
  weddingMonth      Int?
  childrenInfant    Int @default(0)
  childrenPreschool Int @default(0)
  childrenTeen      Int @default(0)
  parentsCount      Int @default(0)
  parentsInLawCount Int @default(0)

  insurancePremium Decimal @default(0) @db.Decimal(15, 2)
  loanInterest     Decimal @default(0) @db.Decimal(15, 2)
  payDay           Int?

  level Int

  flagAutoAmount    Boolean @default(false)
  flagRepReturn     Boolean @default(false)
  flagSpouseReceipt Boolean @default(false)
  flagWorkerNet     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  levelOverrides   Level5Override[]
  quarterlyConfigs QuarterlyEmployeeConfig[]
  monthlyNotes     MonthlyEmployeeNote[]

  @@unique([tenantId, employeeCode])
}

model LevelPaymentRule {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  year     Int
  level    Int
  eventKey String
  amount   Decimal @db.Decimal(15, 2)

  @@unique([tenantId, year, level, eventKey])
}

model Level5Override {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  year       Int
  eventKey   String
  amount     Decimal  @db.Decimal(15, 2)

  @@unique([employeeId, year, eventKey])
}

model LevelTarget {
  id           String  @id @default(cuid())
  tenantId     String
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  year         Int
  level        Int
  targetAmount Decimal @db.Decimal(15, 2)

  @@unique([tenantId, year, level])
}

model QuarterlyRate {
  id                 String  @id @default(cuid())
  tenantId           String
  tenant             Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  year               Int
  itemKey            String
  amountPerInfant    Decimal? @db.Decimal(15, 2)
  amountPerPreschool Decimal? @db.Decimal(15, 2)
  amountPerTeen      Decimal? @db.Decimal(15, 2)
  amountPerParent    Decimal? @db.Decimal(15, 2)
  amountPerInLaw     Decimal? @db.Decimal(15, 2)
  flatAmount         Decimal? @db.Decimal(15, 2)
  percentInsurance   Decimal? @db.Decimal(7, 4)
  percentLoanInterest Decimal? @db.Decimal(7, 4)

  @@unique([tenantId, year, itemKey])
}

model QuarterlyEmployeeConfig {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  year         Int
  itemKey      String
  paymentMonth Int
  amount       Decimal  @db.Decimal(15, 2)

  @@unique([employeeId, year, itemKey])
}

model MonthlyEmployeeNote {
  id                  String   @id @default(cuid())
  employeeId          String
  employee            Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  year                Int
  month               Int
  optionalWelfareText String?
  optionalExtraAmount Decimal? @db.Decimal(15, 2)

  @@unique([employeeId, year, month])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userId    String?
  action    String
  entity    String
  entityId  String?
  payload   Json?
  createdAt DateTime @default(now())
}

model GlSyncJob {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status    String
  payload   Json?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
