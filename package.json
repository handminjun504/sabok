{
  "name": "sabok",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node run-dev.mjs",
    "dev:web": "node run-dev.mjs -- -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "start:web": "next start -H 0.0.0.0 -p $PORT",
    "lint": "next lint",
    "sheet:parity": "tsx scripts/sheet-parity.ts",
    "sheet:snapshots": "bash scripts/refresh-sheet-snapshots.sh",
    "pb:seed": "tsx scripts/pb-seed.ts",
    "pb:create-user": "tsx scripts/pb-create-user.ts",
    "pb:fix-employees-schema": "node scripts/pb-fix-employees-schema.mjs",
    "pb:fix-employees-schema:verbose": "cross-env PB_VERBOSE=1 node scripts/pb-fix-employees-schema.mjs",
    "pb:fix-employees-schema:dry": "cross-env DRY_RUN=1 node scripts/pb-fix-employees-schema.mjs"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.3",
    "bcryptjs": "^3.0.2",
    "jose": "^6.0.10",
    "next": "^15.2.4",
    "pocketbase": "^0.26.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.3",
    "tsx": "^4.19.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.2.4",
    "typescript": "^5.8.3"
  }
}
