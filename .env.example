# 복사해 .env 로 쓰거나, 저장소의 .env 를 그대로 사용하세요.
# DB 는 PocketBase 단독입니다. (PostgreSQL/Prisma/NextAuth 사용 안 함)

# ─── PocketBase 관리자 (서버에서만 사용) ───────────────────────────────
POCKETBASE_URL="http://127.0.0.1:8090"
POCKETBASE_ADMIN_EMAIL="admin@example.com"
POCKETBASE_ADMIN_PASSWORD="change-me"

# ─── 세션 ──────────────────────────────────────────────────────────────
# 16자 이상 권장(32자 이상 안전). 노출 시 모든 세션이 위조 가능 — 운영 키는 안전한 곳에.
SESSION_SECRET="개발용-32자이상랜덤문자열로교체하세요"

# HTTPS(Caddy 등)로만 접속하면 1. 내부 HTTP만 쓰면 비우거나 0.
# COOKIE_SECURE=1

# HTTP 수신 포트 — run-prod.mjs · PM2 기동 시 필요. 로컬은 비우면 Next 기본 3000.
# PORT=

# ─── 단일 사용자 / 다업체 시드 (npm run pb:seed) ──────────────────────
# 한 명의 ADMIN(플랫폼 관리자) 계정만 만든다.
# 이 계정 하나로 「거래처 선택」 화면에서 모든 업체를 추가·전환·삭제할 수 있다.
# 시드는 upsert — 다시 돌리면 비밀번호·이름이 갱신되므로 분실 시 복구용으로 그대로 사용.
SABOK_USER_EMAIL="me@example.com"
SABOK_USER_PASSWORD="ChangeMe!2026"
# (선택) 표시 이름. 비우면 이메일 @ 앞부분.
# SABOK_USER_NAME="관리자"

# (선택) 시드 실행 시 함께 만들 첫 업체. 비우면 업체는 만들지 않고
# 로그인 후 화면에서 직접 추가한다(다업체 운영자에게 권장).
# SABOK_TENANT_CODE="default"
# SABOK_TENANT_NAME="첫 거래처"

# ─── 단일 업체 모드(보통 사용 안 함) ──────────────────────────────────
# 값이 채워져 있으면 「거래처 선택」 화면이 사라지고 항상 이 업체로 들어간다.
# 다업체 운영(여러 회사를 한 계정으로 관리)이면 반드시 비워 두세요.
# SABOK_SINGLE_TENANT_ID=
