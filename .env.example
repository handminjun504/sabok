# 복사해 .env 로 쓰거나, 저장소의 .env 를 그대로 사용하세요.
# PostgreSQL / Prisma / NextAuth 는 사용하지 않습니다. DB 역할은 PocketBase만 합니다.

# PocketBase (GL 서버 등). Admin 계정으로 서버에서만 접근합니다.
POCKETBASE_URL="http://127.0.0.1:8090"
POCKETBASE_ADMIN_EMAIL="admin@example.com"
POCKETBASE_ADMIN_PASSWORD="change-me"

SESSION_SECRET="개발용-32자이상랜덤문자열로교체하세요"

# 프로덕션(PM2·run-prod.mjs). 미설정 시 기본 10002. Caddy·다른 앱과 포트 겹치면 여기서 변경.
# PORT=10002

# HTTPS(Caddy 등)로만 접속하면 1. 내부 HTTP만 쓰면 비우거나 0
# COOKIE_SECURE=1

# PM2 기동 시마다 pb:seed 돌리려면 1 (기본은 안 함 — 수동 npm run pb:seed 권장)
# SABOK_RUN_SEED_ON_START=1
